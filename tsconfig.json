{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["jest", "node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/config/*": ["src/config/*"],
      "@/database/*": ["src/database/*"],
      "@/common/*": ["src/common/*"],
      "@/redis/*": ["src/redis/*"],
      "@/health/*": ["src/health/*"]
    }
  }
}
